PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/book_exchange?schema=public"

# CORS (comma-separated origins for production, or single URL for dev)
CORS_ORIGIN="http://localhost:5173"

# Clerk Auth
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# AWS S3 (for book photo uploads)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET_NAME="my-book-bucket"

# SMTP Email (Nodemailer — for exchange notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
